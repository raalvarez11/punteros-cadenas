#include <stdio.h>
#include <conio.h>
#include <stdlib.h>

int contarPares(int *arr, int tam);

int contarPares(int *arr, int tam){
    int *p, c = 0;
    for(p = arr; p < arr + tam; p++){
        if(*p % 2 == 0)
            c = c + 1;
    }
    return c;
}

int main(int argc, char** argv) {
    int nums[5] = {3, 6, 9, 12, 15};
    printf("Cantidad de numeros pares: %d\n", contarPares(nums, 5));

    system("pause");
    return 0;
}
