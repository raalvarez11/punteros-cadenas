#include <stdio.h>
#include <conio.h>
#include <stdlib.h>

void intercambiar(int *x, int *y);

void intercambiar(int *x, int *y){
    int aux;
    aux = *x;
    *x = *y;
    *y = aux;
}

int main(int argc, char** argv) {
    int a, b;
    printf("Ingrese dos numeros: ");
    scanf("%d %d", &a, &b);
    printf("Antes: a = %d, b = %d\n", a, b);
    intercambiar(&a, &b);
    printf("Despues: a = %d, b = %d\n", a, b);

    system("pause");
    return 0;
}
